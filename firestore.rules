rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Packages (public read, admin write) ───────────────────
    match /packages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Downloads (auth read, admin write) ────────────────────
    match /downloads/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────
    match /orders/{id} {
      allow read:   if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Site Content (public read, admin write) ───────────────
    match /siteContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Announcements (public read, admin write) ──────────────
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
